# ThreatLandscape Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# Application
HOST=0.0.0.0
PORT=5000
DATA_DIR=./data

# LLM Provider selection: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4.1-mini  # Optional, defaults to gpt-4.1-mini

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # Optional, defaults to claude-haiku-4-5-20251001

# Malpedia API (Optional, for threat intelligence)
MALPEDIA_API_KEY=your-malpedia-key-here

# Email Notifications (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=recipient@example.com
